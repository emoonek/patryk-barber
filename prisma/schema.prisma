generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  customer
  admin
}

enum BookingStatus {
  confirmed
  cancelled_by_client
  cancelled_by_admin
  completed
  no_show
}

enum BookingActorType {
  customer
  admin
  system
}

enum AvailabilityExceptionType {
  blocked
  extra_open
}

enum MessageChannel {
  email
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  emailVerifiedAt  DateTime?
  passwordHash     String
  role             UserRole  @default(customer)
  firstName        String?
  lastName         String?
  phone            String?
  isActive         Boolean   @default(true)
  isBlocked        Boolean   @default(false)
  blockedReason    String?
  blockedAt        DateTime?
  blockedByAdminId String?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  bookings              Booking[]                @relation("CustomerBookings")
  bookingStatusChanges  BookingStatusHistory[]   @relation("BookingStatusActor")
  customerNotes         CustomerNote[]           @relation("CustomerNotes")
  customerNotesAuthored CustomerNote[]           @relation("CustomerNotesAuthored")
  emailTokens           EmailVerificationToken[]
  passwordResetTokens   PasswordResetToken[]
  uploadedGalleryImages GalleryImage[]           @relation("GalleryUploadedBy")

  @@index([role])
  @@index([emailVerifiedAt])
  @@index([isBlocked])
  @@map("users")
}

model Service {
  id              String   @id @default(cuid())
  name            String   @unique
  slug            String   @unique
  description     String?
  priceCents      Int
  durationMinutes Int      @default(60)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings Booking[]

  @@index([isActive, sortOrder])
  @@map("services")
}

model Booking {
  id                             String        @id @default(cuid())
  customerId                     String
  serviceId                      String
  serviceNameSnapshot            String
  servicePriceCentsSnapshot      Int
  serviceDurationMinutesSnapshot Int
  status                         BookingStatus @default(confirmed)
  activeSlotKey                  String?       @unique
  startAt                        DateTime
  endAt                          DateTime
  customerMessage                String?
  adminNote                      String?
  cancelledAt                    DateTime?
  completedAt                    DateTime?
  noShowAt                       DateTime?
  createdAt                      DateTime      @default(now())
  updatedAt                      DateTime      @updatedAt

  customer      User                   @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Restrict)
  service       Service                @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  statusHistory BookingStatusHistory[]

  @@index([customerId, startAt])
  @@index([serviceId])
  @@index([status, startAt])
  @@map("bookings")
}

model BookingStatusHistory {
  id          String           @id @default(cuid())
  bookingId   String
  fromStatus  BookingStatus?
  toStatus    BookingStatus
  actorType   BookingActorType
  actorUserId String?
  reason      String?
  createdAt   DateTime         @default(now())

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  actorUser User?   @relation("BookingStatusActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([bookingId, createdAt])
  @@index([actorUserId])
  @@map("booking_status_history")
}

model GalleryImage {
  id           String   @id @default(cuid())
  title        String?
  altText      String
  imageUrl     String
  thumbnailUrl String?
  storageKey   String?
  sortOrder    Int      @default(0)
  isPublished  Boolean  @default(true)
  uploadedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  uploadedBy User? @relation("GalleryUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([isPublished, sortOrder])
  @@map("gallery_images")
}

model AvailabilityRule {
  id          String   @id @default(cuid())
  dayOfWeek   Int
  startTime   String
  endTime     String
  slotMinutes Int      @default(60)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([dayOfWeek, startTime, endTime])
  @@index([dayOfWeek, isActive])
  @@map("availability_rules")
}

model AvailabilityException {
  id        String                    @id @default(cuid())
  type      AvailabilityExceptionType
  startsAt  DateTime
  endsAt    DateTime
  reason    String?
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  @@index([startsAt, endsAt])
  @@index([type])
  @@map("availability_exceptions")
}

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  authorId   String?
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer User  @relation("CustomerNotes", fields: [customerId], references: [id], onDelete: Cascade)
  author   User? @relation("CustomerNotesAuthored", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([customerId, createdAt])
  @@index([authorId])
  @@map("customer_notes")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}
